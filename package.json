{
  "name": "freewhen",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "pages:dev": "wrangler pages dev dist --compatibility-date=2025-01-01 --compatibility-flags=nodejs_compat",
    "deploy": "npm run build && wrangler pages deploy dist --project-name freewhen",
    "tail": "wrangler pages deployment tail --project-name freewhen",
    "migrate:local": "wrangler d1 migrations apply freewhen --local",
    "migrate:remote": "wrangler d1 migrations apply freewhen --remote",
    "test": "vitest run && vitest run --config vitest.workers.config.ts",
    "test:ui": "vitest",
    "test:workers": "vitest run --config vitest.workers.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "framer-motion": "^11.5.4",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-day-picker": "^9.0.0",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.1",
    "tailwind-merge": "^2.5.2"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.5.0",
    "@cloudflare/workers-types": "^4.20240903.0",
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "jsdom": "^25.0.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.11",
    "typescript": "^5.5.4",
    "vite": "^5.4.4",
    "vitest": "^2.0.5",
    "wrangler": "^4.82.2"
  }
}
